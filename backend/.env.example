# Required. Postgres connection string from Neon, Railway, Vercel Postgres, etc.
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Required for LLM-based filtering. Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional. Default: 3001
PORT=3001

# Optional. Set a strong secret in production.
JWT_SECRET=your-secret-here
